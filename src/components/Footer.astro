---
import data from '../data/data.json';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const year = new Date().getFullYear();
const today = new Date().toISOString().split('T')[0];
---

<footer class="site-footer">
  <p>
    {t(locale, 'footer.disclaimer', { title: data.titre })}
  </p>
  <p class="updated">{t(locale, 'footer.last_updated', { date: today })} &middot; &copy; {year} {data.titre}</p>
  <p class="updated" style="margin-top: 0.375rem;">
    <a href="https://judata.app" target="_blank" rel="noopener noreferrer" style="color: #8B5CF6; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
      Judata &mdash; Track your judo
    </a>
  </p>
</footer>
