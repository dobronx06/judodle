---
import data from '../data/data.json';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { t, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<header class="site-header">
  <a href={localePath(locale)} class="site-logo">{data.titre}</a>
  <nav>
    <span
      id="streak-display"
      class="streak-display"
      style="padding: 0.25rem 0.5rem; margin: 0;"
      aria-label={t(locale, 'game.streak_label')}
    >
      <span aria-hidden="true">&#x1F525;</span>
      <span class="streak-count" id="streak-count">0</span>
    </span>
    <LanguageSwitcher locale={locale} />
  </nav>
</header>
