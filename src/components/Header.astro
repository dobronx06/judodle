---
import data from '../data/data.json';
---

<header class="site-header">
  <a href="/" class="site-logo">{data.titre}</a>
  <nav>
    <span
      id="streak-display"
      class="streak-display"
      style="padding: 0.25rem 0.5rem; margin: 0;"
      aria-label="Serie en cours"
    >
      <span aria-hidden="true">🔥</span>
      <span class="streak-count" id="streak-count">0</span>
    </span>
  </nav>
</header>
